PORT=5000
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRE=7d

# Option 1: full connection URL
DATABASE_URL=mysql://user:password@host:3306/database

# Option 2: split variables
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nayafood_ems
DB_USER=root
DB_PASSWORD=password

# Railway MySQL variables are also supported automatically:
# MYSQLHOST
# MYSQLPORT
# MYSQLDATABASE
# MYSQLUSER
# MYSQLPASSWORD
# MYSQL_URL

# Set this to true only if your MySQL connection requires SSL
DB_SSL=false
